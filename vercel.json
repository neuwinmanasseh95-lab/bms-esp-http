{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "functions": {
    "api/bms.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/bms",  "dest": "/api/bms.js"     },
    { "src": "/(.*)",     "dest": "/public/$1"       }
  ],
  "env": {
    "API_SECRET": "qwertyuiopasdfghjklzxcvbnm1234567890"
  }
}
